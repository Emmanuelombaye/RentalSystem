generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  LANDLORD
  TENANT
}

enum UserStatus {
  active
  inactive
  pending
}

// ─── User (Auth) ─────────────────────────────────────────────────────────

model User {
  id                 String               @id @default(cuid())
  name               String
  email              String               @unique
  password           String
  role               Role                 @default(TENANT)
  status             UserStatus           @default(pending)
  tenantProfile      Tenant?              @relation("UserTenant")
  ownedProperties    Property[]           @relation("LandlordProperties")
  passwordResetTokens PasswordResetToken[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([email])
  @@index([role])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// ─── Property & Unit ─────────────────────────────────────────────────────

model Property {
  id         String   @id @default(cuid())
  name       String
  address    String
  type       String
  status     String   @default("active")
  landlordId String?
  landlord   User?    @relation("LandlordProperties", fields: [landlordId], references: [id])
  images     String?
  units      Unit[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([landlordId])
}

model Unit {
  id          String               @id @default(cuid())
  label       String
  propertyId  String
  property    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  status      String               @default("vacant")
  rent        Float
  tenantId    String?
  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  leases      Lease[]
  payments    Payment[]
  maintenance MaintenanceRequest[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([propertyId])
  @@index([tenantId])
}

// ─── Tenant ───────────────────────────────────────────────────────────────

model Tenant {
  id          String               @id @default(cuid())
  userId      String?              @unique
  user        User?                @relation("UserTenant", fields: [userId], references: [id])
  name        String
  email       String               @unique
  phone       String?
  status      String               @default("active")
  units       Unit[]
  leases      Lease[]
  payments    Payment[]
  maintenance MaintenanceRequest[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([email])
}

// ─── Lease ────────────────────────────────────────────────────────────────

model Lease {
  id            String    @id @default(cuid())
  unitId        String
  unit          Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  rentAmount    Float
  depositAmount Float     @default(0)
  dueDay        Int       @default(1)
  lateFee       Float     @default(0)
  contractUrl   String?
  status        String    @default("active")
  payments      Payment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

// ─── Payment ──────────────────────────────────────────────────────────────

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leaseId     String?
  lease       Lease?   @relation(fields: [leaseId], references: [id])
  amount      Float
  status      String   @default("pending")
  paymentType String   @default("rent")
  method      String?
  reference   String?
  receiptUrl  String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([leaseId])
}

// ─── Maintenance ──────────────────────────────────────────────────────────

model MaintenanceRequest {
  id                  String   @id @default(cuid())
  unitId              String
  unit                Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issue               String
  description         String?
  priority            String   @default("medium")
  status              String   @default("pending")
  assignedTechnician  String?
  cost                Float?
  invoiceUrl          String?
  images              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([unitId])
  @@index([tenantId])
}
