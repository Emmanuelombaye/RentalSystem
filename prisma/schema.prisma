generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LANDLORD
  TENANT
}

enum Status {
  active
  inactive
  pending
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(TENANT)
  status    Status   @default(pending)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  landlordProperties Property[]           @relation("LandlordProperties")
  tenantProfile      Tenant?              @relation("UserTenant")
  resetTokens        PasswordResetToken[]

  @@index([email])
  @@index([role])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}


model Tenant {
  id          String               @id @default(cuid())
  userId      String?              @unique
  user        User?                @relation("UserTenant", fields: [userId], references: [id])
  name        String
  email       String               @unique
  phone       String?
  status      String
  units       Unit[]
  leases      Lease[]
  payments    Payment[]
  maintenance MaintenanceRequest[]
  riskScores  TenantRiskScore[]
  conversations AIConversation[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId])
  @@index([email])
}

model AIConversation {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  message   String
  response  String
  type      String   // maintenance, payment, general, guest
  status    String   // auto_replied, ai_handled, manual_intervention
  context   String?  // JSON string for AI context
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model TenantRiskScore {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  score     Int      // 0-100
  level     String   // Low, Medium, High
  factors   String?  // JSON string of risk factors
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model MaintenancePrediction {
  id          String   @id @default(cuid())
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  component   String   // AC, Pump, Roof, etc.
  probability Float    // 0.0 - 1.0
  reason      String
  suggestedAt DateTime
  status      String   @default("pending") // pending, addressed, ignored
  createdAt   DateTime @default(now())

  @@index([unitId])
}

model SecurityAlert {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type        String   // unusual_motion, door_opened, sound_detected
  severity    String   // low, medium, high, critical
  snapshotUrl String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([propertyId])
}

model MpesaTransaction {
  id            String   @id @default(cuid())
  merchantId    String   // MerchantRequestID
  checkoutId    String   @unique // CheckoutRequestID
  amount        Float
  phone         String
  status        String   @default("pending") // pending, completed, failed
  mpesaReceipt  String?  @unique
  resultDesc    String?
  transactionAt DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([checkoutId])
}

model Property {
  id         String   @id @default(cuid())
  name       String
  address    String
  type       String
  status     String
  landlordId String?
  landlord   User?    @relation("LandlordProperties", fields: [landlordId], references: [id])
  units      Unit[]
  securityAlerts SecurityAlert[]
  images     String?  // JSON string or URL
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([landlordId])
}

model Unit {
  id          String               @id @default(cuid())
  label       String
  propertyId  String
  property    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  status      String
  rent        Float
  tenantId    String?
  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  leases      Lease[]
  payments    Payment[]
  maintenance MaintenanceRequest[]
  predictions MaintenancePrediction[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([propertyId])
  @@index([tenantId])
}

model Lease {
  id             String    @id @default(cuid())
  unitId         String
  unit           Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  rentAmount     Float
  depositAmount  Float     @default(0)
  dueDay         Int       @default(1) // 1-31
  lateFee        Float     @default(0)
  contractUrl    String?
  status         String    @default("active") // active, terminated, expired
  payments       Payment[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

model Payment {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId       String
  unit         Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leaseId      String?
  lease        Lease?   @relation(fields: [leaseId], references: [id])
  amount       Float
  status       String   @default("pending") // pending, paid, rejected, refunded
  paymentType  String   @default("rent") // rent, deposit, late_fee, maintenance
  method       String?  // mpesa, bank_transfer, cash
  reference    String?  // MPESA Code etc
  receiptUrl   String?
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([unitId])
  @@index([leaseId])
}

model MaintenanceRequest {
  id                 String   @id @default(cuid())
  unitId             String
  unit               Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issue              String
  description        String?
  priority           String
  status             String   @default("pending") // pending, in_progress, completed, cancelled
  assignedTechnician String?
  cost               Float?
  invoiceUrl         String?
  images             String?  // JSON string of images
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([unitId])
  @@index([tenantId])
}
